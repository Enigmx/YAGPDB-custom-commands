{{else}}
{{sendMessage nil (complexMessage "content" (print "<#" $b.ID ">") "components" (cslice (cbutton "label" "Edit" "custom_id" (print "forumAutoMessageEdit" $b.ID) "style" "grey")  (cbutton "label" "Remove" "custom_id" (print "forumAutoMessageRemove" $b.ID) "style" "red")) "embed" (cembed "title" $c "description" $d "color" $e))}}
