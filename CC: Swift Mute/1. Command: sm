{{/* configuration */}}
{{$limit := 50}}
{{$staffchannel := 0}}
{{$mutedrole := 0}}
{{$duration := 600}}
{{/* end configuration */}}

{{if .ExecData}}
{{$a := index .ExecData 0}}
{{$b := index .ExecData 1}}
{{if not $b}}
{{return}}
{{end}}
{{$c := false}}
{{try}}
{{exec "clear" (index $b 0) $a}}
{{catch}}
{{.Error}}
{{execCC $.CCID nil 4 (cslice $a $b)}}
{{return}}
{{end}}
{{$d := cslice}}
{{range $b}}
{{if $c}}
{{$d = $d.Append .}}
{{else}}
{{$c = true}}
{{end}}
{{end}}
{{execCC .CCID nil 11 (cslice $a $d)}}
{{return}}
{{end}}
{{deleteTrigger 0}}
{{if not (getChannel $staffchannel)}}
This Custom Command has not been configured properly; a log channel has not been set. 
Edit the second line of the code: \{\{$staffchannel := 0\}\}, replace 0 with the channel ID where logs will be sent.
{{return}}
{{end}}
{{if not (getRole $mutedrole)}}
This Custom Command has not been configured properly; a muted role has not been sent.
Edit the third line of the code: \{\{$mutedrole := 0\}\}, replace 0 with the muted role ID. People will be added this role if they are swift muted.
{{return}}
{{end}}
{{if eq (len .Args) 1}}
### Swift mute
**{{.ServerPrefix}}sm [targets] [number of messages to delete]**: Mute members and delete their messages
{{return}}
{{end}}
{{$a := reFindAll `\d{15,20}` .Message.Content}}
{{$b := cslice}}
{{range $a}}
{{if not (in $b (toInt .))}}
{{$b = $b.Append (toInt .)}}
{{end}}
{{end}}
{{$c := reFind `\b(?:100|[1-9][0-9]?)\b` .Message.Content | toInt}}
{{$e := cslice}}
{{if ge (len $b) 31}}
{{sendMessage $staffchannel "You can swift mute 30 members at most :("}}
{{$f := 0}}
{{$g := cslice}}
{{range $b}}
{{$f = add $f 1}}
{{if eq $f 31}}
{{$b = $g}}
{{break}}
{{end}}
{{$g = $g.Append .}}
{{end}}
{{end}}
{{range $b}}
{{if $d := getMember .}}
{{$e = $e.Append $d.User.Username}}
{{giveRoleID $d.User.ID $mutedrole}}
{{takeRoleID $d.User.ID $mutedrole $duration}}
{{sendMessage $staffchannel (complexMessage "content" (print $d.User.ID) "embed" (cembed "author" (sdict "name" ($.User.Username) "icon_url" ($.User.AvatarURL "512")) "description" (print "**" $.User.Username "** swift muted **" $d.User.Username "**") "color" 0x5eeb83))}}
{{end}}
{{end}}
{{if ne (len $b) 1}}
{{$h := cslice}}
{{range $b}}
{{$h = $h.Append (str .)}}
{{end}}
{{sendMessage $staffchannel (complexMessage "content" (joinStr " " $h) "embed" (cembed "author" (sdict "name" ($.User.Username) "icon_url" ($.User.AvatarURL "512")) "description" (print "**" $.User.Username "** swift muted **" (joinStr "**, **" $e) "**") "color" 0xeb5ea))}}
{{end}}
{{if le $limit $c}}
{{sendMessage $staffchannel (print "You can delete **" $limit "** messages at most per person :(")}}
{{$c = $limit}}
{{end}}
{{if $c}}
{{execCC .CCID nil 0 (cslice $c $b)}}
{{end}}
